---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Search from "astro-pagefind/components/Search";
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-10">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
		<nav class="flex flex-col sm:flex-row items-center justify-between h-auto sm:h-16 py-4 sm:py-0 gap-4 sm:gap-0">
			<h2 class="text-xl font-bold text-gray-900 tracking-tight flex-shrink-0">
				<a href="/" class="hover:text-blue-600 transition-colors">{SITE_TITLE}</a>
			</h2>
			<div class="flex space-x-1 sm:space-x-4">
				<HeaderLink href="/" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-md transition-colors">
					トップ
				</HeaderLink>
				<HeaderLink href="/blog" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-md transition-colors">
					すべての記事
				</HeaderLink>
			</div>
			
			<div class="w-full sm:w-64">
				<Search 
					id="search" 
					className="pagefind-ui" 
					uiOptions={{ 
						showImages: false, 
						placeholder: '記事を検索...', 
						translations: {
							placeholder: "記事を検索...",
							clear_search: "クリア",
							load_more: "さらに読み込む",
							search_label: "検索",
							filters_label: "フィルター",
							zero_results: "[SEARCH_TERM] に一致する結果はありませんでした。",
							many_results: "[SEARCH_TERM] で [COUNT] 件の結果が見つかりました。",
							one_result: "[SEARCH_TERM] で 1 件の結果が見つかりました。",
							alt_search: "[SEARCH_TERM] に一致する結果はありませんでした。代わりに [DIFFERENT_TERM] で検索しました。",
							search_suggestion: "[SEARCH_TERM] に一致する結果はありませんでした。次のいずれかをお試しください: [SEARCH_TERM]",
							searching: "[SEARCH_TERM] を検索しています..."
						}
					}} 
				/>
			</div>
		</nav>
	</div>
</header>

<style is:global>
	/* Pagefind UI Customization for Tailwind */
	.pagefind-ui {
		--pagefind-ui-scale: 0.8;
		--pagefind-ui-primary: #2563eb; /* blue-600 */
		--pagefind-ui-text: #111827; /* gray-900 */
		--pagefind-ui-background: #ffffff;
		--pagefind-ui-border: #e5e7eb; /* gray-200 */
		--pagefind-ui-tag: #f3f4f6; /* gray-100 */
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 0.5rem;
		--pagefind-ui-image-border-radius: 0.5rem;
		--pagefind-ui-image-box-ratio: 3 / 2;
		--pagefind-ui-font: 'Inter', 'Noto Sans JP', sans-serif;
	}

	.pagefind-ui .pagefind-ui__search-input {
		font-weight: normal;
		box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
	}

	.pagefind-ui .pagefind-ui__drawer {
		position: absolute;
		top: 100%;
		right: 0;
		left: 0;
		margin-top: 0.5rem;
		background: var(--pagefind-ui-background);
		z-index: 50;
		border: 1px solid var(--pagefind-ui-border);
		border-radius: var(--pagefind-ui-border-radius);
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
		padding: 1rem;
		max-height: 80vh;
		overflow-y: auto;
	}
	
	@media (min-width: 640px) {
		.pagefind-ui .pagefind-ui__drawer {
			left: auto;
			width: 400px;
		}
	}
	
	.pagefind-ui .pagefind-ui__hidden {
		display: none;
	}
</style>
