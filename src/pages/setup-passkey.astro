---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`パスキー生成 | ${SITE_TITLE}`} description="管理用パスキーの生成ページ" />
        <script is:inline src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans">
		<Header />
		<main class="max-w-2xl mx-auto px-4 py-10">
			<div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
				<h1 class="text-2xl font-bold mb-6">🔑 パスキーの生成（1回限りの初期設定）</h1>
				
				<p class="text-gray-600 mb-6 text-sm">
					パスワードを入力して「指紋認証等でパスキーを作成する」ボタンを押すと、このデバイスにパスキーが登録され、2つの専用キーが即座に発行されます。
				</p>

				<form id="setup-form" class="space-y-6">
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-2">現在のパスワードを入力してください</label>
						<input type="password" id="password" required
							class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500" 
							placeholder="ADMIN_PASSWORDを入力">
					</div>

					<button type="submit" id="submit-btn"
						class="w-full bg-blue-600 text-white font-bold py-3 px-4 rounded-md hover:bg-blue-700 transition disabled:opacity-50">
						指紋認証等でパスキーを作成する
					</button>
				</form>

                <div id="result-area" class="mt-8 hidden p-6 bg-green-50 border border-green-200 rounded-lg">
                    <h2 class="text-lg font-bold text-green-800 mb-4">✅ パスキーの作成に成功しました！</h2>
                    <p class="text-sm text-green-700 mb-4 font-bold">
                        以下の2つの値をコピーして、VercelのEnvironment Variablesに新しく追加してください。（設定後、VercelでRedeployが必要です）
                    </p>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-800">PASSKEY_CREDENTIAL_ID</label>
                            <input type="text" id="credential-id" readonly class="w-full px-3 py-2 bg-white border border-green-300 rounded text-sm font-mono mt-1" onfocus="this.select()" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-800">PASSKEY_PUBLIC_KEY</label>
                            <input type="text" id="public-key" readonly class="w-full px-3 py-2 bg-white border border-green-300 rounded text-sm font-mono mt-1" onfocus="this.select()" />
                        </div>
                    </div>
                </div>

                <div id="error-msg" class="hidden mt-6 p-4 bg-red-50 text-red-700 border border-red-200 rounded-md text-sm"></div>
			</div>
		</main>
		<Footer />

		<script is:inline>
			const form = document.getElementById('setup-form');
			const submitBtn = document.getElementById('submit-btn');
            const errorMsg = document.getElementById('error-msg');
            const resultArea = document.getElementById('result-area');

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				
				const password = document.getElementById('password').value;
				
				submitBtn.disabled = true;
                errorMsg.classList.add('hidden');
                resultArea.classList.add('hidden');

				try {
                    // 1. オプション取得
					const optRes = await fetch('/api/auth/generate-registration-options', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password })
					});
                    if (!optRes.ok) throw new Error((await optRes.json()).error);
                    
                    const options = await optRes.json();
                    
                    // 2. ブラウザのパスキーUI表示
                    const { startRegistration } = window.SimpleWebAuthnBrowser;
                    const attResp = await startRegistration(options);

                    // 3. サーバーへ検証送信
                    const verifyRes = await fetch('/api/auth/verify-registration', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(attResp)
                    });
                    
                    if (!verifyRes.ok) throw new Error((await verifyRes.json()).error);
                    const verifyData = await verifyRes.json();

                    if (verifyData.verified) {
                        document.getElementById('credential-id').value = verifyData.credentialID;
                        document.getElementById('public-key').value = verifyData.publicKey;
                        resultArea.classList.remove('hidden');
                    }

				} catch (err) {
                    errorMsg.textContent = err.message || 'エラーが発生しました';
                    errorMsg.classList.remove('hidden');
				} finally {
					submitBtn.disabled = false;
				}
			});
		</script>
	</body>
</html>
